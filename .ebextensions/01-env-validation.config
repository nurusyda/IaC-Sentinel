container_commands:
  01_validate_env:
    command: |
      python3 - << 'EOF'
      import os, sys

      REQUIRED = [
          "SESSION_SECRET_KEY",
          "AUTH0_DOMAIN",
          "AUTH0_CLIENT_ID",
          "AUTH0_CLIENT_SECRET",
          "AUTH0_GITHUB_AUTHORIZE_URL",
          "REDIRECT_URI",
          "DEEPSEEK_API_KEY",
          "XAI_API_KEY",
      ]

      missing = [v for v in REQUIRED if not os.environ.get(v)]
      if missing:
          print(f"[FATAL] Missing required environment variables: {', '.join(missing)}", flush=True)
          sys.exit(1)

      print("[OK] All required environment variables are present.", flush=True)
      EOF